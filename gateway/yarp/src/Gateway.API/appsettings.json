{
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "store-route": {
        "ClusterId": "store-cluster",
        "Match": {
          "Path": "/stores/{**catch-all}"
        }
      },
      "media-route": {
        "ClusterId": "media-cluster",
        "Match": {
          "Path": "/media/{**catch-all}"
        }
      },
      "pet-route": {
        "ClusterId": "pet-cluster",
        "Match": {
          "Path": "/pets/{**catch-all}"
        }
      },
      "adoption-route": {
        "ClusterId": "adoption-cluster",
        "Match": {
          "Path": "/adoptions/{**catch-all}"
        }
      },
      "community-route": {
        "ClusterId": "community-cluster",
        "Match": {
          "Path": "/community/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-service": {
            "Address": "http://pncm_identity:8080"
          }
        }
      },
      "store-cluster": {
        "Destinations": {
          "store-service": {
            "Address": "http://pncm_store:8080"
          }
        }
      },
      "media-cluster": {
        "Destinations": {
          "media-service": {
            "Address": "http://pncm_media:8080"
          }
        }
      },
      "pet-cluster": {
        "Destinations": {
          "pet-service": {
            "Address": "http://pncm_pet:8080"
          }
        }
      },
      "adoption-cluster": {
        "Destinations": {
          "adoption-service": {
            "Address": "http://pncm_adoption:8080"
          }
        }
      },
      "community-cluster": {
        "Destinations": {
          "community-service": {
            "Address": "http://pncm_community:8080"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-service": {
            "Address": "http://pncm_notification:8080"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}