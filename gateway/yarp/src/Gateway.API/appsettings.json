{
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "store-route": {
        "ClusterId": "store-cluster",
        "Match": {
          "Path": "/stores/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-service": {
            "Address": "http://pncm_identity:8080"
          }
        }
      },
      "store-cluster": {
        "Destinations": {
          "store-service": {
            "Address": "http://pncm_store:8080"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}